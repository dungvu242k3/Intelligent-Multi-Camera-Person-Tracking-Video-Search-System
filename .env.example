# =====================================================
# Intelligent Multi-Camera Person Tracking System
# Environment Configuration Template
# =====================================================

# ---- General ----
COMPOSE_PROJECT_NAME=mcpt
ENVIRONMENT=development
ENV=development

# ---- PostgreSQL ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=mcpt_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=mcpt_db
DATABASE_URL=postgresql+asyncpg://mcpt_user:change_me_in_production@postgres:5432/mcpt_db

# ---- DB Connection Pool ----
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379

# ---- Kafka ----
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_TRACKING=tracking-events
KAFKA_TOPIC_ALERTS=alert-events
KAFKA_GROUP_ID=mcpt-backend

# ---- Qdrant (Vector DB) ----
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION_REID=person_embeddings

# ---- MinIO (Object Storage) ----
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_CROPS=person-crops
MINIO_BUCKET_CLIPS=video-clips

# ---- Backend (FastAPI) ----
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=4
SECRET_KEY=change_me_in_production_use_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
JWT_REFRESH_EXPIRE_DAYS=30
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- Internal Auth ----
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_SERVICE_KEY=change_this_internal_key_in_production

# ---- Service URLs ----
GATEWAY_ALERTS_URL=http://gateway:8000/api/v1/alerts/publish
NOTIFICATION_SERVICE_PORT=8005

# ---- Frontend (React) ----
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000/ws

# ---- DeepStream / AI Pipeline ----
DEEPSTREAM_CONFIG_PATH=/app/configs/deepstream_app.yml
TRITON_SERVER_URL=triton:8001
REID_MODEL_NAME=osnet_x1_0
DETECTOR_MODEL_NAME=yolov8m
GPU_DEVICE_ID=0

# ---- Monitoring ----
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=admin
LOKI_URL=http://loki:3100
JAEGER_AGENT_HOST=jaeger
JAEGER_AGENT_PORT=6831
