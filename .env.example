# =====================================================
# Intelligent Multi-Camera Person Tracking System
# Environment Configuration Template
# =====================================================

# ---- General ----
COMPOSE_PROJECT_NAME=mcpt
ENVIRONMENT=development

# ---- PostgreSQL ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=mcpt_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=mcpt_db

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- Kafka ----
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_TRACKING=tracking-events
KAFKA_TOPIC_ALERTS=alert-events
KAFKA_GROUP_ID=mcpt-backend

# ---- Qdrant (Vector DB) ----
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION_REID=person_embeddings

# ---- MinIO (Object Storage) ----
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_CROPS=person-crops
MINIO_BUCKET_CLIPS=video-clips

# ---- Backend (FastAPI) ----
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=4
SECRET_KEY=change_me_in_production_use_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---- Frontend (React) ----
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000/ws

# ---- DeepStream / AI Pipeline ----
DEEPSTREAM_CONFIG_PATH=/app/configs/deepstream_app.yml
TRITON_SERVER_URL=triton:8001
REID_MODEL_NAME=osnet_x1_0
DETECTOR_MODEL_NAME=yolov8m
GPU_DEVICE_ID=0

# ---- Monitoring ----
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=admin
LOKI_URL=http://loki:3100
JAEGER_AGENT_HOST=jaeger
JAEGER_AGENT_PORT=6831
