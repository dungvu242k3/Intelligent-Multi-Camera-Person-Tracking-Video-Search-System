# =====================================================
# AI/ML Models (Root models/)
# =====================================================
# Ignore all large model binary weights globally
*.pt
*.pth
*.onnx
*.engine
*.plan
*.trt
*.pb
*.weights

# Specifically ignore model checkpoints and weights under models/
models/checkpoints/
models/yolo/**/*.pt
models/yolo/**/*.onnx
models/yolo/**/*.engine
models/reid/**/*.pt
models/reid/**/*.onnx
models/reid/**/*.engine
models/tensorrt/

# DO NOT ignore model configs, text files, and READMEs
!models/configs/
!models/configs/**/*.yaml
!models/configs/**/*.txt
!models/scripts/
!models/scripts/**/*.py
!models/README.md

# =====================================================
# Datasets (Root datasets/)
# =====================================================
# Ignore all raw/processed images, videos, and labels
datasets/raw/**/*
datasets/processed/**/*
datasets/annotations/**/*
datasets/training/**/*
datasets/validation/**/*

# Keep folder structures by not ignoring .gitkeep files
!datasets/**/.gitkeep
!datasets/README.md

# =====================================================
# Monitoring & Metrics
# =====================================================
prometheus_data/
grafana_data/

# =====================================================
# IDEs & System files
# =====================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# =====================================================
# Log files & Temporary folders
# =====================================================
*.log
tmp/
temp/

# =====================================================
# Agent Runtime Directories
# =====================================================
.agent/

